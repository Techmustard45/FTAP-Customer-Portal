@model Laptimes

<div class="container mt-5" style="max-width: 600px;">

    <!-- Header -->
    <div class="text-center mb-4">
        <h2>Add New Laptime</h2>
        <p class="text-muted">@Model.racername</p>
    </div>

    <!-- Form Card -->
    <div class="card">
        @using (Html.BeginForm("AddLaptimeToDatabase", "Laptimes", FormMethod.Post))
        {
            <input asp-for="customerid" type="hidden" value="@Model.customerid" />
            <input asp-for="racername" type="hidden" value="@Model.racername" />

            <div class="form-group mb-3">
                <label asp-for="laptime">New Laptime</label>
                <input type="number" step="0.001" name="laptime" class="form-control" placeholder="e.g. 52.347" />
            </div>

            <div class="form-group mb-4">
                <label asp-for="kart">Kart #</label>
                <input type="number" name="kart" class="form-control" placeholder="Enter kart number" />
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between">

                <a href="/Laptimes/ViewRacer/@Model.customerid" class="btn btn-outline">
                    ⬅ Cancel
                </a>

                <input type="submit" value="Add Laptime" class="btn btn-red px-4" />
            </div>
        }
    </div>

</div>