@model IEnumerable<Laptimes>
<head>
    <link rel="stylesheet" href="~/FTAP_Portal.styles.css" asp-append-version="true"/>
</head>

@{
    ViewData["Title"] = "Laptimes";
}

<div class="container mt-4">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Laptimes Leaderboard</h2>
        <a href="" class="btn btn-primary">Refresh</a>
    </div>
    
    @{
        var top3 = Model.Take(3).ToList();
    }
    
    @if (top3.Count >= 3)
    {
        <div class="podium-container mb-4">

            <!-- 2nd -->
            <div class="podium-card silver">
                <div class="podium-rank">🥈 2</div>
                <div class="podium-name">@top3[1].racername</div>
                <div class="podium-time">@top3[1].laptime</div>
            </div>

            <!-- 1st -->
            <div class="podium-card gold podium-winner">
                <div class="podium-rank">🥇 1</div>
                <div class="podium-name">@top3[0].racername</div>
                <div class="podium-time">@top3[0].laptime</div>
            </div>

            <!-- 3rd -->
            <div class="podium-card bronze">
                <div class="podium-rank">🥉 3</div>
                <div class="podium-name">@top3[2].racername</div>
                <div class="podium-time">@top3[2].laptime</div>
            </div>

        </div>
    }

    <!-- Search -->
    <div class="mb-3">
        <input type="text" id="searchInput" class="form-control" placeholder="Search racer name...">
    </div>

    <!-- Table -->
    <table class="table table-hover" id="laptimeTable">
        <thead>
        <tr>
            <th>Ranking</th>
            <th>Laptime</th>
            <th>Racer Name</th>
            <th>Kart #</th>
        </tr>
        </thead>
        <tbody>
        @{ int ranking = 1; }
        @foreach (var laptimes in Model)
        {
            var rowClass = ranking == 1 ? "gold"
                : ranking == 2 ? "silver"
                : ranking == 3 ? "bronze"
                : "";

            <tr class="@rowClass">
                <td>@ranking</td>
                <td>@laptimes.laptime</td>
                <td>
                    <a href="Laptimes/ViewRacer/@laptimes.customerid">
                        @laptimes.racername
                    </a>
                </td>
                <td>@laptimes.kart</td>
            </tr>

            ranking++;
        }
        </tbody>
    </table>
</div>

<script>
    document.getElementById("searchInput").addEventListener("keyup", function () {
        let filter = this.value.toLowerCase();
        let rows = document.querySelectorAll("#laptimeTable tbody tr");

        rows.forEach(row => {
            let name = row.cells[2].innerText.toLowerCase();
            row.style.display = name.includes(filter) ? "" : "none";
        });
    });
</script>